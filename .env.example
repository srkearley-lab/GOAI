# ============================================================
# GO AI — environment variables
# Copy to .env.local and fill in. NEVER commit .env.local.
# ============================================================

# --- Firebase Admin (server-only — DO NOT prefix with NEXT_PUBLIC_) ---
# Create a Firebase project, then: Project Settings > Service accounts >
# "Generate new private key". Use the values from the downloaded JSON.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the private key with literal \n escapes (keep the surrounding quotes).
# Example: "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

# --- Resend email delivery (server-only) — emails each proposal to the team ---
# Resend API key (https://resend.com/api-keys). RESEND_FROM must be on your
# verified Resend domain (e.g. updates.go-ai.gr); RESEND_TO is where leads land.
RESEND_API_KEY=
RESEND_FROM=GO AI <leads@updates.go-ai.gr>
RESEND_TO=support@go-ai.gr

# --- Generation pipeline (server-only) — Hermes sample-site agent on the VPS ---
# HERMES_VPS_ENDPOINT: the VPS job-receiver URL the brief is POSTed to on submit.
#   Leave blank to disable generation (leads still email + store as normal).
# GENERATION_SHARED_SECRET: HMAC secret shared with the VPS — signs the outbound
#   enqueue and verifies the inbound /api/generate/callback. Use a long random value.
# The VPS agent emails the prospect directly (proposal PDF + sample link) using
# its own RESEND_* config; this app only records the outcome via the callback.
# The callback URL is built from NEXT_PUBLIC_SITE_URL as <site>/api/generate/callback.
HERMES_VPS_ENDPOINT=
GENERATION_SHARED_SECRET=
# Set to "true" only once the pipeline is live — gates the "we're building your
# sample" confirmation copy so prospects are never promised a sample prematurely.
NEXT_PUBLIC_GENERATION_ENABLED=

# --- Admin dashboard (server-only) ---
# /admin signs in with Firebase Auth (Email/Password or Google — enable the
# providers in the Firebase console). Only these emails are allowed in
# (comma-separated, case-insensitive). Unset = nobody can access /admin.
# NOTE: add your production domains (go-ai.gr, www.go-ai.gr, *.vercel.app) under
# Firebase console -> Authentication -> Settings -> Authorized domains.
ADMIN_ALLOWED_EMAILS=

# --- Firebase Web SDK (client) — /admin sign-in ---
# Public identifiers from Firebase console -> Project settings -> Your apps.
# Safe to expose (shipped to the browser); access control is server-side.
# NEXT_PUBLIC_* values are inlined at BUILD time — set in Vercel + redeploy.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Lead delivery fallback (server-only, optional) ---
# If Firebase is NOT configured, each proposal is POSTed as JSON to this webhook
# (Zapier / Make / n8n / your own endpoint). Return any 2xx to confirm receipt.
# If neither Firebase nor this webhook is set, the wizard never fakes success —
# it shows the prefilled WhatsApp fallback so the lead still reaches you.
LEAD_WEBHOOK_URL=

# --- Public (safe to expose to the browser) ---
# Business WhatsApp number in international format, digits only (no + or spaces).
# Example: 306900000000
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Canonical site URL — drives metadata, OG/Twitter tags, sitemap, robots & JSON-LD.
# No trailing slash. REQUIRED in production: when unset, robots.txt disallows all
# so non-production hosts are never indexed.
NEXT_PUBLIC_SITE_URL=https://go-ai.gr
