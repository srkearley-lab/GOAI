# ============================================================
# GO AI — environment variables
# Copy to .env.local and fill in. NEVER commit .env.local.
# ============================================================

# --- Firebase Admin (server-only — DO NOT prefix with NEXT_PUBLIC_) ---
# Create a Firebase project, then: Project Settings > Service accounts >
# "Generate new private key". Use the values from the downloaded JSON.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the private key with literal \n escapes (keep the surrounding quotes).
# Example: "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

# --- Resend email delivery (server-only) — emails each proposal to the team ---
# Resend API key (https://resend.com/api-keys). RESEND_FROM must be on your
# verified Resend domain (e.g. updates.go-ai.gr); RESEND_TO is where leads land.
RESEND_API_KEY=
RESEND_FROM=GO AI <leads@updates.go-ai.gr>
RESEND_TO=support@go-ai.gr

# --- Lead delivery fallback (server-only, optional) ---
# If Firebase is NOT configured, each proposal is POSTed as JSON to this webhook
# (Zapier / Make / n8n / your own endpoint). Return any 2xx to confirm receipt.
# If neither Firebase nor this webhook is set, the wizard never fakes success —
# it shows the prefilled WhatsApp fallback so the lead still reaches you.
LEAD_WEBHOOK_URL=

# --- Public (safe to expose to the browser) ---
# Business WhatsApp number in international format, digits only (no + or spaces).
# Example: 306900000000
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Canonical site URL — drives metadata, OG/Twitter tags, sitemap, robots & JSON-LD.
# No trailing slash. REQUIRED in production: when unset, robots.txt disallows all
# so non-production hosts are never indexed.
NEXT_PUBLIC_SITE_URL=https://go-ai.gr
